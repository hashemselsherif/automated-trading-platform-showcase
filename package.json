{
  "name": "jupiter-perps-bot",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "test": "node --test tests/**/*.test.js",
    "test:modules": "node scripts/test/audit-all-modules.js",
    "lint": "eslint . --ext .js --ignore-path .gitignore",
    "lint:fix": "eslint . --ext .js --ignore-path .gitignore --fix",
    "format": "prettier --write \"**/*.{js,json,md}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{js,json,md}\" --ignore-path .gitignore",
    "start": "node bot.js",
    "start:prod": "NODE_ENV=production node bot.js",
    "dev": "node bot.js",
    "backtest": "node scripts/backtest/backtest.js",
    "backtest:scalping": "node scripts/backtest/backtest-scalping.js",
    "backtest:scalping:multi": "bash scripts/backtest/backtest-scalping-multi.sh",
    "pm2:start": "pm2 start ./ecosystem.config.js",
    "pm2:stop": "pm2 stop jupiter-perps-bot",
    "pm2:restart": "pm2 restart jupiter-perps-bot",
    "pm2:logs": "pm2 logs jupiter-perps-bot",
    "pm2:status": "pm2 status",
    "validate-env": "node tools/validate-env.js",
    "validate-environments": "node tools/validate-environments.js",
    "encrypt-wallet": "node tools/encrypt-wallet.js",
    "re-encrypt-wallet": "node tools/re-encrypt-wallet.js",
    "generate-new-wallet": "node tools/secrets-manager.js",
    "validate-wallet-json": "node tools/validate-wallet-json.js",
    "wallet": "node tools/secrets-manager.js",
    "generate-api-key": "node -e \"console.log(require('crypto').randomBytes(32).toString('hex'))\"",
    "get-telegram-chat-id": "node tools/get-telegram-chat-id.js",
    "validate-telegram-token": "node tools/validate-telegram-token.js",
    "setup-telegram": "node tools/setup-telegram.js",
    "secrets": "node tools/secrets-manager.js",
    "generate-erd-pdf": "node scripts/generate-erd-pdf.js docs/ERD.md",
    "generate-master-pdf": "node scripts/generate-erd-pdf.js docs/MASTER_DOCUMENT.md",
    "create-file": "node scripts/create-file.js",
    "check-structure": "node scripts/check-structure.js",
    "rotate:logs": "bash scripts/rotate-logs.sh",
    "control": "node control-panel.js",
    "cp": "node control-panel.js",
    "dashboard": "node dashboard.js",
    "monitor": "node dashboard.js",
    "db": "node scripts/query-db.js",
    "healthcheck": "node -e \"const http = require('http'); const config = require('./config'); const port = config.uiPort || 3000; const req = http.get({hostname: 'localhost', port, path: '/api/status', timeout: 5000}, (res) => { process.exit(res.statusCode === 200 ? 0 : 1); }); req.on('error', () => process.exit(1)); req.on('timeout', () => { req.destroy(); process.exit(1); });\"",
    "health": "npm run healthcheck",
    "validate-health": "node scripts/test/validate-health.js",
    "smoke-tests": "node scripts/test/smoke-tests.js",
    "smoke-drift": "node scripts/test/smoke-drift-devnet-readonly.js",
    "drift:install": "cd drift-subprocess && npm install",
    "drift:test": "cd drift-subprocess && npm test",
    "drift:subprocess-test": "node scripts/test/test-drift-subprocess.js",
    "drift:client-test": "node scripts/test/test-drift-client-paper.js",
    "drift:generate-registry": "node scripts/generate-drift-market-registry.js",
    "check-instances": "bash scripts/check-bot-instances.sh",
    "stop-local": "bash scripts/stop-local-instances.sh",
    "setup-render": "bash scripts/setup-render-url.sh",
    "check-balance": "node scripts/check-wallet-balance.js",
    "drift:validate-config": "node tools/validate-drift-config.js",
    "test:drift": "node tests/drift/run-all.js",
    "test:drift:single": "node",
    "drift:e2e": "node scripts/test/e2e-drift-lifecycle.js",
    "drift:dual-test": "node scripts/test/test-dual-strategy.js",
    "drift:price-test": "node scripts/test/test-price-provider.js",
    "drift:shadow-report": "node -e \"const {getShadowModeManager}=require('./utils/shadow-mode');console.log(JSON.stringify(getShadowModeManager().getReport(),null,2))\""
  },
  "postinstall": "cd drift-subprocess && npm install --no-audit --no-fund",
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.32.1",
    "@drift-labs/sdk": "^2.151.0",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "axios": "^1.13.1",
    "better-sqlite3": "^12.4.1",
    "blessed": "^0.1.81",
    "blessed-contrib": "^4.11.0",
    "bn.js": "^5.2.2",
    "bs58": "^6.0.0",
    "chalk": "^4.1.2",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "inquirer": "^8.2.5",
    "jup-perps-client": "^1.0.0",
    "node-telegram-bot-api": "^0.66.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "dotenv-cli": "^11.0.0",
    "eslint": "^8.57.0",
    "md-to-pdf": "^5.2.4",
    "prettier": "^3.2.5"
  },
  "overrides": {
    "form-data": "^4.0.0",
    "tough-cookie": "^4.1.3",
    "bigint-buffer": "^1.1.5",
    "request": "^2.88.2"
  }
}
